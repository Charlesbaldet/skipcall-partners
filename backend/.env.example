# ─── Server ───
PORT=4000
NODE_ENV=development

# ─── Database ───
DATABASE_URL=postgresql://user:password@localhost:5432/skipcall_referrals

# ─── JWT ───
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_EXPIRES_IN=7d

# ─── Email (SMTP) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@skipcall.com
SMTP_PASS=your_app_password
EMAIL_FROM="Skipcall <notifications@skipcall.com>"

# ─── Frontend URL (for CORS & email links) ───
FRONTEND_URL=http://localhost:5173
